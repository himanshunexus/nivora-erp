# Production Environment Variables for Render Deployment

# Django Core (REQUIRED)
DJANGO_SECRET_KEY=<generate-with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())">
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=yourdomain.onrender.com,www.yourdomain.onrender.com

# Database (Render provides automatically if configured)
DATABASE_URL=postgresql://user:password@host:port/dbname

# Redis Cache & Celery (Render provides automatically if configured)
REDIS_URL=redis://:password@host:port

# CSRF & Security
DJANGO_CSRF_TRUSTED_ORIGINS=https://yourdomain.onrender.com,https://www.yourdomain.onrender.com
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0

# Email Configuration (Optional - uses console.EmailBackend in production if not set)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-specific-password
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# JWT Configuration
JWT_ACCESS_TTL_MINUTES=60
JWT_REFRESH_TTL_MINUTES=10080
OTP_EXPIRY_MINUTES=10

# Notification polling
NOTIFICATION_POLL_INTERVAL_MS=30000

# Celery (auto-configured if REDIS_URL available)
CELERY_BROKER_URL=redis://:password@host:port
CELERY_RESULT_BACKEND=redis://:password@host:port
